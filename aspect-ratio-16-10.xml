<!-- 
16:10 aspect ratio
-->
<theme>
	<!--
	///
	All Views
	///
	-->
	<view name="system,gamelist">
		<image name="system-controller">
			<maxSize>0.0444444444444444 0.06</maxSize>
		</image>	
		
		<systemstatus name="system-status">
			<pos>0.9075 0.0990740740740741</pos>
		</systemstatus>
	</view>
	
	<!--
	///
	System View
	///
	-->	
	<view name="system">
		<carousel name="system-carousel">
			<itemSize>0.200520833333333 0.320833333333333</itemSize>
		</carousel>
		<animation name="system-selector">
			<size>0.207465277777777 0.331944444444444</size>
		</animation>

		<image name="system-game-card">
			<pos>0.070572917 0.233564796296297</pos>
		</image>
		<text name="systemName, autoCollectionName, customCollectionName">
			<pos>0.104137728458333 0.233564796296297</pos>
		</text>
		
		<image name="system-user-icon-background">
			<size>0.049768519 0</size>
		</image>
		<image name="system-user-icon-background-color">
			<size>0.049768519 0</size>
		</image>
		<image name="system-user-icon">
			<maxSize>0.043402778 0.069444444</maxSize>
		</image>
	</view>
	
	<!--
	///
	Gamelist View
	///
	-->
	<view name="gamelist">
		<systemstatus name="system-status">
			<pos>2 2</pos>
		</systemstatus>
		<text name="game-name">
			<pos>0.133564811458333 0.138888889</pos>
			<size>0.766435188541667 0.0333333333333333</size>
		</text>
	</view>
	
	<!--
	///
	Variant - No Home Menu Graphics
	///
	-->
	<variant name="switch2-no-menu, switch1-no-menu">
		<view name="system">
			<image name="system-game-card">
				<pos>0.070572917 0.277546296</pos> 
			</image>
			<text name="systemName, autoCollectionName, customCollectionName">
				<pos>0.104137728458333 0.277546296</pos>
			</text>
		</view>
	</variant>
	
</theme>