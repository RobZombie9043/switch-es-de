<!-- 
8:7 aspect ratio
-->
<theme>
	<!--
	///
	All Views
	///
	-->
	<view name="system,gamelist">
		<image name="system-controller">
			<maxSize>0.0412903225806452 0.04</maxSize>
		</image>	
		
		<systemstatus name="system-status">
			<pos>0.88 0.0990740740740741</pos>
		</systemstatus>
	</view>
	
	<!--
	///
	System View
	///
	-->	
	<view name="system">
		<image name="system-menu-bar-background">
			<maxSize>0.75 0.1125</maxSize>
		</image>
		<image name="system-menu-bar">
			<maxSize>0.75 0.1125</maxSize>
		</image>
		<carousel name="system-carousel">
			<itemSize>0.2005208333333333 0.230227623</itemSize>
			<imageCornerRadius>0.0120967741935484</imageCornerRadius>
		</carousel>
		<animation name="system-selector">
			<pos>0.0699600137741935 0.4560185</pos>
			<size>0.211811155913978 0.246894290123456</size>
		</animation>
		
		<image name="system-game-card">
			<pos>0.070572917 0.278867651</pos> 
		</image>
		<text name="systemName, autoCollectionName, customCollectionName">
			<pos>0.117347106 0.278867651</pos>	
		</text>
		
		<image name="system-user-icon-background">
			<size>0.069354839 0</size>
		</image>
		<image name="system-user-icon-background-color">
			<size>0.069354839 0</size>
		</image>
		<image name="system-user-icon">
			<maxSize>0.059677419 0.069444444</maxSize>
		</image>
	</view>
	
	<!--
	///
	Gamelist View
	///
	-->
	<view name="gamelist">
		<systemstatus name="system-status">
			<pos>2 2</pos>
		</systemstatus>
		<text name="game-name">
			<pos>0.146774188870968 0.138888889</pos>
			<size>0.753225811129032 0.0333333333333333</size>
		</text>
	</view>
	
	<!--
	///
	Variant - Switch 1
	///
	-->
	<variant name="switch1, switch1-no-menu">
		<view name="system">
			<carousel name="system-carousel">
				<imageCornerRadius>0</imageCornerRadius>
			</carousel>
		</view>
		
		<view name="gamelist"> 
			<grid name="game-grid">
				<imageCornerRadius>0</imageCornerRadius>
				<textBackgroundCornerRadius>0</textBackgroundCornerRadius>
			</grid>
		</view>		
	</variant>
	
	<!--
	///
	Variant - No Home Menu Graphics
	///
	-->
	<variant name="switch2-no-menu, switch1-no-menu">
		<view name="system">
			<image name="system-game-card">
				<pos>0.070572917 0.322849151</pos>  
			</image>
			<text name="systemName, autoCollectionName, customCollectionName">
				<pos>0.117347106 0.322849151</pos>
			</text>
			<animation name="system-selector">
				<pos>0.0699600137741935 0.5</pos>
			</animation>
		</view>
	</variant>
	
</theme>