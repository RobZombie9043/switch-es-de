<!-- 
16:9 aspect ratio
-->
<theme>
	<!--
	///
	All Views
	///
	-->
	<view name="system,gamelist">
		<image name="system-controller">
			<maxSize>0.04 0.06</maxSize>
		</image>	
		
		<systemstatus name="system-status">
			<pos>0.9075 0.0990740740740741</pos>
		</systemstatus>
	</view>
	
	<!--
	///
	System View
	///
	-->	
	<view name="system">
		<carousel name="system-carousel">
			<itemSize>0.200520833333333 0.356481481481481</itemSize>
			<imageCornerRadius>0.009375</imageCornerRadius>
		</carousel>
		<animation name="system-selector">
			<pos>0.066885417 0.4560185</pos>
			<size>0.216145833333333 0.384259259259259</size>
		</animation>

		<image name="system-game-card">
			<pos>0.070572917 0.215740722222223</pos>
		</image>
		<text name="systemName, autoCollectionName, customCollectionName">
			<pos>0.1007812473125 0.215740722222223</pos>
		</text>
		
		<image name="system-user-icon-background">
			<size>0.044791667 0</size>
		</image>
		<image name="system-user-icon-background-color">
			<size>0.044791667 0</size>
		</image>
		<image name="system-user-icon">
			<maxSize>0.0390625 0.069444444</maxSize>
		</image>
	</view>
	
	<!--
	///
	Gamelist View
	///
	-->
	<view name="gamelist">
		<systemstatus name="system-status">
			<pos>2 2</pos>
		</systemstatus>
		<text name="game-name">
			<pos>0.1302083303125 0.138888889</pos>
			<size>0.7697916696875 0.0333333333333333</size>
		</text>
	</view>
	
	<!--
	///
	Variant - Switch 1
	///
	-->
	<variant name="switch1, switch1-no-menu">
		<view name="system">
			<carousel name="system-carousel">
				<imageCornerRadius>0</imageCornerRadius>
			</carousel>
		</view>
		
		<view name="gamelist"> 
			<grid name="game-grid">
				<imageCornerRadius>0</imageCornerRadius>
				<textBackgroundCornerRadius>0</textBackgroundCornerRadius>
			</grid>
		</view>		
	</variant>
	
	<!--
	///
	Variant - No Home Menu Graphics
	///
	-->
	<variant name="switch2-no-menu, switch1-no-menu">
		<view name="system">
			<image name="system-game-card">
				<pos>0.070572917 0.259722222</pos>
			</image>
			<text name="systemName, autoCollectionName, customCollectionName">
				<pos>0.1007812473125 0.259722222</pos>
			</text>
		</view>
	</variant>
	
</theme>