<!-- 
3:2 aspect ratio
-->
<theme>
	<!--
	///
	All Views
	///
	-->
	<view name="system,gamelist">
		<image name="system-controller">
			<maxSize>0.0474074074074074 0.06</maxSize>
		</image>
		
		<systemstatus name="system-status">
			<pos>0.9 0.0990740740740741</pos>
		</systemstatus>	
	</view>
	
	<!--
	///
	System View
	///
	-->	
	<view name="system">
		<image name="system-menu-bar-background">
			<maxSize>0.7 0.1125</maxSize>
		</image>
		<image name="system-menu-bar">
			<maxSize>0.7 0.1125</maxSize>
		</image>
		<carousel name="system-carousel">
			<itemSize>0.200520833333333 0.30078125</itemSize>
			<imageCornerRadius>0.0111111111111111</imageCornerRadius>
		</carousel>
		<animation name="system-selector">
			<pos>0.0697210651481481 0.4560185</pos>
			<size>0.209780092592592 0.323003472222222</size>
		</animation>

		<image name="system-game-card">
			<pos>0.070572917 0.243590837962963</pos>
		</image>
		<text name="systemName, autoCollectionName, customCollectionName">
			<pos>0.106375382555556 0.243590837962963</pos>
		</text>
		
		<image name="system-user-icon-background">
			<size>0.05308642 0</size>
		</image>
		<image name="system-user-icon-background-color">
			<size>0.05308642 0</size>
		</image>
		<image name="system-user-icon">
			<maxSize>0.046296296 0.069444444</maxSize>
		</image>
	</view>
	
	<!--
	///
	Gamelist View
	///
	-->
	<view name="gamelist">
		<systemstatus name="system-status">
			<pos>2 2</pos>
		</systemstatus>
		<text name="game-name">
			<pos>0.135802465555556 0.138888889</pos>
			<size>0.764197534444444 0.0333333333333333</size>
		</text>
	</view>
		
	<!--
	///
	Variant - Switch 1
	///
	-->
	<variant name="switch1, switch1-no-menu">
		<view name="system">
			<carousel name="system-carousel">
				<imageCornerRadius>0</imageCornerRadius>
			</carousel>
		</view>
		
		<view name="gamelist"> 
			<grid name="game-grid">
				<imageCornerRadius>0</imageCornerRadius>
				<textBackgroundCornerRadius>0</textBackgroundCornerRadius>
			</grid>
		</view>		
	</variant>
	
	<!--
	///
	Variant - No Home Menu Graphics
	///
	-->
	<variant name="switch2-no-menu, switch1-no-menu">
		<view name="system">
			<image name="system-game-card">
				<pos>0.070572917 0.287572338</pos>
			</image>
			<text name="systemName, autoCollectionName, customCollectionName">
				<pos>0.106375382555556 0.287572338</pos>
			</text>
			<animation name="system-selector">
				<pos>0.0697210651481481 0.5</pos>
			</animation>
		</view>
	</variant>
	
</theme>