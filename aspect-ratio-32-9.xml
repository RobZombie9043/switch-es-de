<!-- 
32:9 aspect ratio
-->
<theme>
	<!--
	///
	All Views
	///
	-->
	<view name="system,gamelist">
		<image name="system-controller">
			<maxSize>0.02 0.06</maxSize>
		</image>	
		
		<systemstatus name="system-status">
			<pos>0.925 0.0990740740740741</pos>
		</systemstatus>
	</view>
	
	<!--
	///
	System View
	///
	-->	
	<view name="system">
		<carousel name="system-carousel">
			<itemSize>0.100260416666666 0.356481481481481</itemSize>
			<maxItemCount>7.6</maxItemCount>
			<horizontalOffset>-0.390039063</horizontalOffset>
			<imageCornerRadius>0.005859375</imageCornerRadius>
		</carousel>
		<animation name="system-selector">
			<pos>0.056705729 0.4560185</pos>
			<size>0.107291666666666 0.381481481481481</size>
		</animation>

		<image name="system-game-card">
			<pos>0.059830729 0.215740722</pos>
		</image>
		<text name="systemName, autoCollectionName, customCollectionName">
			<pos>0.074934894 0.215740722</pos>
		</text>
		
		<image name="system-user-icon-background">
			<size>0.022395833 0</size>
		</image>
		<image name="system-user-icon-background-color">
			<size>0.022395833 0</size>
		</image>
		<image name="system-user-icon">
			<maxSize>0.01953125 0.069444444</maxSize>
		</image>
	</view>
	
	<!--
	///
	Gamelist View
	///
	-->
	<view name="gamelist">
		<systemstatus name="system-status">
			<pos>2 2</pos>
		</systemstatus>
		<text name="game-name">
			<pos>0.11510416515625 0.138888889</pos>
			<size>0.78489583484375 0.0333333333333333</size>
		</text>
		<grid name="game-grid">
			<imageCornerRadius>0.005</imageCornerRadius>
			<textBackgroundCornerRadius>0.005</textBackgroundCornerRadius>
		</grid>
	</view>
	
	<!--
	///
	Variant - Switch 1
	///
	-->
	<variant name="switch1, switch1-no-menu">
		<view name="system">
			<carousel name="system-carousel">
				<imageCornerRadius>0</imageCornerRadius>
			</carousel>
		</view>
		
		<view name="gamelist"> 
			<grid name="game-grid">
				<imageCornerRadius>0</imageCornerRadius>
				<textBackgroundCornerRadius>0</textBackgroundCornerRadius>
			</grid>
		</view>		
	</variant>
	
	<!--
	///
	Variant - No Home Menu Graphics
	///
	-->
	<variant name="switch2-no-menu, switch1-no-menu">
		<view name="system">
			<image name="system-game-card">
				<pos>0.059830729 0.259722222</pos> 
			</image>
			<text name="systemName, autoCollectionName, customCollectionName">
				<pos>0.074934894 0.259722222</pos>
			</text>
			<animation name="system-selector">
				<pos>0.056705729 0.5</pos>
			</animation>
		</view>
	</variant>
	
</theme>